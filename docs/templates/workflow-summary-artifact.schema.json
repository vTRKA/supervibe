{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://supervibe.local/schemas/workflow-summary-artifact.schema.json",
  "title": "Supervibe Workflow Summary Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractVersion",
    "artifactKind",
    "summaryId",
    "workflowId",
    "stage",
    "stageOrder",
    "title",
    "createdAt",
    "expiresAt",
    "storagePath",
    "sourcePrompt",
    "sourceArtifact",
    "summary",
    "approvedScope",
    "assumptions",
    "planningAssumptions",
    "constraints",
    "risks",
    "missingFacts",
    "visualSummary",
    "decisionSummary",
    "staleState",
    "choices",
    "approvalState",
    "evidenceAppendix",
    "artifactHash"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "contractVersion": { "enum": ["workflow-summary-v2"] },
    "artifactKind": { "const": "workflow-summary" },
    "summaryId": { "type": "string", "minLength": 1 },
    "workflowId": { "type": "string", "minLength": 1 },
    "stage": { "enum": ["pre-spec", "post-spec", "pre-plan", "post-plan"] },
    "stageOrder": { "type": "integer", "minimum": 1, "maximum": 4 },
    "title": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "expiresAt": { "type": "string", "minLength": 1 },
    "storagePath": {
      "type": "string",
      "pattern": "^\\.supervibe/artifacts/summaries/.+/(pre-spec-summary|post-spec-summary|pre-plan-summary|post-plan-summary)\\.json$"
    },
    "sourcePrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hash", "capturedAt", "excerpt"],
      "properties": {
        "hash": { "$ref": "#/$defs/sha256" },
        "capturedAt": { "type": "string", "minLength": 1 },
        "excerpt": { "type": "string" }
      }
    },
    "sourceArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "hashAlgorithm", "hash", "capturedAt"],
      "properties": {
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "hashAlgorithm": { "const": "sha256" },
        "hash": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "const": "" }] },
        "capturedAt": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objective", "scope", "nonGoals"],
      "properties": {
        "objective": { "type": "string" },
        "scope": { "$ref": "#/$defs/stringArray" },
        "nonGoals": { "$ref": "#/$defs/stringArray" }
      }
    },
    "approvedScope": { "$ref": "#/$defs/stringArray" },
    "assumptions": { "$ref": "#/$defs/stringArray" },
    "planningAssumptions": { "$ref": "#/$defs/stringArray" },
    "constraints": { "$ref": "#/$defs/stringArray" },
    "risks": { "$ref": "#/$defs/stringArray" },
    "missingFacts": { "$ref": "#/$defs/stringArray" },
    "visualSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "summaryTable", "asciiMap"],
      "properties": {
        "required": { "const": true },
        "summaryTable": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "value": { "type": "string", "minLength": 1 }
            }
          }
        },
        "asciiMap": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decisionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["addedAndWhy", "deferredAndWhy", "validationResult", "nextRecommendedCommand", "nextUserActions"],
      "properties": {
        "addedAndWhy": { "$ref": "#/$defs/stringArray" },
        "deferredAndWhy": { "$ref": "#/$defs/stringArray" },
        "validationResult": { "type": "string" },
        "nextRecommendedCommand": { "type": "string" },
        "nextUserActions": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "staleState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason", "checkedAt", "sourceArtifactHash", "repair"],
      "properties": {
        "status": { "enum": ["current", "unknown", "stale"] },
        "reason": { "type": "string" },
        "checkedAt": { "type": "string" },
        "sourceArtifactHash": { "type": "string" },
        "repair": { "type": "string" }
      }
    },
    "choices": { "$ref": "#/$defs/choices" },
    "approvalState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "selectedChoiceId", "approvedAt", "approvedBy", "approvalSource", "allowedChoiceIds", "sourcePromptHash", "artifactHash", "expiresAt"],
      "properties": {
        "status": { "enum": ["pending", "approved", "rejected", "expired"] },
        "selectedChoiceId": { "type": "string" },
        "approvedAt": { "type": "string" },
        "approvedBy": { "type": "string" },
        "approvalSource": { "const": "latest-user-gate" },
        "allowedChoiceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" } },
        "sourcePromptHash": { "$ref": "#/$defs/sha256" },
        "artifactHash": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "const": "" }] },
        "expiresAt": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceAppendix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaPath", "contractVersion", "storagePath", "sourcePromptHash", "sourceArtifactHash", "artifactHash", "items"],
      "properties": {
        "schemaPath": { "const": "docs/templates/workflow-summary-artifact.schema.json" },
        "contractVersion": { "const": "workflow-summary-v2" },
        "storagePath": { "type": "string", "minLength": 1 },
        "sourcePromptHash": { "$ref": "#/$defs/sha256" },
        "sourceArtifactHash": { "type": "string" },
        "artifactHash": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "const": "" }] },
        "items": { "$ref": "#/$defs/stringArray" }
      }
    },
    "artifactHash": { "$ref": "#/$defs/sha256" }
  },
  "allOf": [
    {
      "if": { "properties": { "stage": { "const": "pre-spec" } } },
      "then": { "properties": { "storagePath": { "pattern": "/pre-spec-summary\\.json$" } } }
    },
    {
      "if": { "properties": { "stage": { "const": "post-spec" } } },
      "then": {
        "properties": {
          "storagePath": { "pattern": "/post-spec-summary\\.json$" },
          "sourceArtifact": {
            "properties": {
              "path": { "minLength": 1 },
              "hash": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "stage": { "const": "pre-plan" } } },
      "then": { "properties": { "storagePath": { "pattern": "/pre-plan-summary\\.json$" } } }
    },
    {
      "if": { "properties": { "stage": { "const": "post-plan" } } },
      "then": {
        "properties": {
          "storagePath": { "pattern": "/post-plan-summary\\.json$" },
          "sourceArtifact": {
            "properties": {
              "path": { "minLength": 1 },
              "hash": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "minLength": 71,
      "maxLength": 71,
      "pattern": "^sha256:[a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9]$"
    },
    "stringArray": { "type": "array", "items": { "type": "string" } },
    "choices": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "description", "recommended", "ordinal"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "recommended": { "type": "boolean" },
          "ordinal": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
