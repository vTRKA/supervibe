{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "scripts/build-registry.mjs",
    "scripts/validate-frontmatter.mjs",
    "scripts/validate-plugin-json.mjs",
    "scripts/lint-skill-descriptions.mjs",
    "scripts/session-start-check.mjs",
    "scripts/post-edit-stack-watch.mjs",
    "scripts/effectiveness-tracker.mjs",
    "scripts/build-memory-index.mjs",
    "scripts/search-memory.mjs",
    "scripts/build-code-index.mjs",
    "scripts/search-code.mjs",
    "scripts/watch-memory.mjs",
    "scripts/evolve-status.mjs",
    "scripts/preview-server.mjs",
    "scripts/discover-mcps.mjs",
    "scripts/validate-agent-output-contract.mjs",
    "scripts/hooks/post-tool-use-log.mjs",
    "scripts/evolve-upgrade.mjs",
    "scripts/evolve-upgrade-check.mjs"
  ],
  "ignoreUnresolved": ["node:sqlite"],
  "project": ["scripts/**/*.mjs", "tests/**/*.mjs"],
  "ignore": ["node_modules/**", "**/*.md"],
  "ignoreDependencies": ["husky", "lint-staged", "@commitlint/cli", "@commitlint/config-conventional"]
}
