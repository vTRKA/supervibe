{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "bin/*.mjs",
    "scripts/*.mjs",
    "scripts/hooks/*.mjs",
    "scripts/lib/memory-preflight.mjs",
    "scripts/lib/regression-scorer.mjs",
    ".husky/*"
  ],
  "ignoreIssues": {
    "scripts/lib/autonomous-loop-provider-policy-guard.mjs": ["exports"],
    "scripts/lib/supervibe-durable-task-tracker-adapter.mjs": ["exports"],
    "scripts/lib/supervibe-work-item-comments.mjs": ["exports"],
    "scripts/lib/supervibe-work-item-query.mjs": ["exports"],
    "scripts/lib/supervibe-work-item-template-catalog.mjs": ["exports"],
    "scripts/lib/supervibe-worktree-session-manager.mjs": ["exports"]
  },
  "project": ["scripts/**/*.mjs", "tests/**/*.mjs"]
}
