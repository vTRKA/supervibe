# Auto detect text files and keep Supervibe instruction/evidence surfaces LF.
* text=auto
.gitattributes text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
**/.gitignore text eol=lf

*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.txt text eol=lf
*.tpl text eol=lf

*.sh text eol=lf
*.{cmd,bat,ps1} text eol=crlf
*.{png,jpg,jpeg,gif,webp,avif,ico,woff,woff2,ttf,otf,eot} binary
