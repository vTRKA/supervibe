          "tier": "balanced",
          "previewOnly": true,
          "preview": "enable memories with bounded local sqlite/history state",
          "sourceUrl": "https://developers.openai.com/codex/config-reference",
          "checkedAt": "2026-05-13"
        },
        {
          "outcome": "safer tools",
          "setting": "approval_policy + sandbox_mode + default_permissions + mcp scopes/timeouts",
          "tier": "safe-default",
          "previewOnly": true,
