{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env['CLAUDE'+'_PLUGIN_ROOT'];if(!r)process.exit(0);await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/session-start-check.mjs",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env['CLAUDE'+'_PLUGIN_ROOT'];if(!r)process.exit(0);await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/hooks/pre-write-prototype-guard.mjs",
            "async": false
          },
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env['CLAUDE'+'_PLUGIN_ROOT'];if(!r)process.exit(0);await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/hooks/pre-tool-use-refactor-advisory.mjs",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env['CLAUDE'+'_PLUGIN_ROOT'];if(!r)process.exit(0);await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/hooks/user-prompt-submit-feedback.mjs",
            "async": true
          },
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env['CLAUDE'+'_PLUGIN_ROOT'];if(!r)process.exit(0);await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/hooks/user-prompt-submit-memory-preflight.mjs",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env['CLAUDE'+'_PLUGIN_ROOT'];if(!r)process.exit(0);await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/post-edit-stack-watch.mjs",
            "async": true
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env['CLAUDE'+'_PLUGIN_ROOT'];if(!r)process.exit(0);await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/hooks/post-tool-use-log.mjs",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env['CLAUDE'+'_PLUGIN_ROOT'];if(!r)process.exit(0);await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/effectiveness-tracker.mjs",
            "async": true
          }
        ]
      }
    ]
  }
}
