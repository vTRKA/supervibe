{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env.PLUGIN_ROOT||process.env[['CLAUDE','PLUGIN_ROOT'].join('_')];if(!r)process.exit(0);process.env.SUPERVIBE_PLUGIN_ROOT=r;await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/session-start-check.mjs",
            "async": false
          },
          {
            "type": "command",
            "command": "node --input-type=module -e \"import{pathToFileURL}from'node:url';import{join}from'node:path';const r=process.env.SUPERVIBE_PLUGIN_ROOT||process.env.PLUGIN_ROOT||process.env[['CLAUDE','PLUGIN_ROOT'].join('_')];if(!r)process.exit(0);process.env.SUPERVIBE_PLUGIN_ROOT=r;await import(pathToFileURL(join(r,process.argv[1])).href)\" scripts/hooks/task-tracker-prime.mjs --text --compact-context",
            "async": false
          }
        ]
      }
    ],
