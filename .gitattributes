# Auto detect text files and perform LF normalization
* text=auto
.gitattributes text eol=lf

# Shell installers are parsed by bash during Windows install checks. Keep them
# LF even when users clone with core.autocrlf=true.
*.sh text eol=lf

# Large ONNX models are downloaded from HuggingFace by the installer and are
# intentionally not stored in git.
#
# WASM grammars are <2.1MB each (~8.3MB total) and are stored as regular blobs.
