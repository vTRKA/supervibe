{
  "name": "supervibe-framework",
  "version": "2.0.26",
  "description": "Dev tooling for the Supervibe Claude Code plugin",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "overrides": {
    "onnxruntime-node": "1.25.1"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:loop": "node --test tests/autonomous-loop-*.test.mjs tests/command-surface.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "test:cross-platform": "node --test tests/cross-platform-process.test.mjs",
    "code:index": "node scripts/build-code-index.mjs",
    "code:search": "node scripts/search-code.mjs",
    "supervibe:status": "node scripts/supervibe-status.mjs",
    "supervibe:loop": "node scripts/supervibe-loop.mjs",
    "supervibe:eval": "node scripts/supervibe-loop.mjs --eval",
    "supervibe:loop:status": "node scripts/supervibe-loop.mjs --status",
    "supervibe:checkpoint-status": "node scripts/supervibe-status.mjs --checkpoint-diagnostics",
    "supervibe:loop:completion": "node scripts/supervibe-loop.mjs --completion bash",
    "supervibe:upgrade": "node scripts/supervibe-upgrade.mjs",
    "supervibe:auto-update": "node scripts/supervibe-auto-update.mjs",
    "supervibe:install-health": "node scripts/supervibe-auto-update.mjs --dry-run --health",
    "ensure:onnx-model": "node scripts/ensure-onnx-model.mjs",
    "supervibe:install-doctor": "node scripts/supervibe-install-doctor.mjs",
    "supervibe:upgrade-check": "node scripts/supervibe-upgrade-check.mjs",
    "supervibe:detect": "node scripts/supervibe-detect.mjs",
    "supervibe:doctor": "node scripts/supervibe-doctor.mjs",
    "supervibe:ui": "node scripts/supervibe-ui.mjs",
    "supervibe:ide-bridge": "node scripts/supervibe-ide-bridge.mjs",
    "supervibe:gc": "node scripts/supervibe-gc.mjs",
    "supervibe:work-items-gc": "node scripts/supervibe-work-items-gc.mjs",
    "supervibe:memory-gc": "node scripts/supervibe-memory-gc.mjs",
    "supervibe:context-pack": "node scripts/supervibe-context-pack.mjs",
    "supervibe:context-eval": "node scripts/supervibe-context-eval.mjs",
    "supervibe:context-quality": "node scripts/supervibe-context-eval.mjs --case-file tests/fixtures/scenario-evals/supervibe-user-flows.json",
    "supervibe:user-outcomes": "node scripts/supervibe-status.mjs --user-outcomes",
    "supervibe:retrieval-pipeline": "node scripts/supervibe-context-eval.mjs --case-file tests/fixtures/scenario-evals/supervibe-user-flows.json --explain",
    "supervibe:knowledge-graph": "node scripts/search-memory.mjs --query \"feedback websocket\" --graph --include-history",
    "supervibe:performance-slo": "node scripts/supervibe-status.mjs --performance-slo",
    "supervibe:workspace-isolation": "node scripts/supervibe-status.mjs --workspace-isolation",
    "supervibe:feedback-learning": "node scripts/regression-suite.mjs --feedback-learning-smoke",
    "supervibe:happy-path": "node scripts/supervibe-happy-path.mjs",
    "supervibe:docs-audit": "node scripts/supervibe-docs-audit.mjs",
    "supervibe:preview": "node scripts/preview-server.mjs",
    "media:capabilities": "node scripts/detect-media-capabilities.mjs",
    "feedback:status": "node scripts/feedback-status.mjs --list",
    "presentation:build": "node scripts/build-presentation.mjs",
    "memory:watch": "node scripts/watch-memory.mjs",
    "registry:build": "node scripts/build-registry.mjs",
    "validate:frontmatter": "node scripts/validate-frontmatter.mjs",
    "lint:descriptions": "node scripts/lint-skill-descriptions.mjs",
    "validate:plugin-json": "node scripts/validate-plugin-json.mjs",
    "validate:agent-footers": "node scripts/validate-agent-output-contract.mjs",
    "validate:design-skills": "node scripts/validate-design-skills.mjs",
    "validate:question-discipline": "node scripts/validate-question-discipline.mjs",
    "validate:spec-artifacts": "node scripts/validate-spec-artifacts.mjs --all",
    "validate:plan-artifacts": "node scripts/validate-plan-artifacts.mjs --all",
    "migrate:prototype-configs": "node scripts/migrate-prototype-configs.mjs",
    "memory:preflight": "node scripts/lib/memory-preflight.mjs",
    "measure:tokens": "node scripts/measure-token-footprint.mjs",
    "validate:no-deep-refs": "node scripts/validate-no-deep-refs.mjs",
    "validate:agent-section-order": "node scripts/validate-agent-section-order.mjs",
    "validate:trigger-metadata": "node scripts/validate-trigger-metadata.mjs",
    "validate:trigger-replay": "node scripts/validate-trigger-replay.mjs",
    "validate:confidence-gates": "node scripts/validate-confidence-gates.mjs",
    "audit:plugin-package": "node scripts/audit-plugin-package.mjs",
    "audit:release-security": "node scripts/audit-release-security.mjs",
    "regression:run": "node scripts/regression-suite.mjs",
    "regression:diff": "node scripts/lib/regression-scorer.mjs",
    "audit:evidence": "node scripts/audit-evidence-citations.mjs",
    "rollout:rag-procedure": "node scripts/apply-rag-memory-procedure.mjs",
    "lint:dead-code": "knip --no-progress --no-config-hints",
    "check": "npm run validate:plugin-json && npm run validate:frontmatter && npm run lint:descriptions && npm run validate:agent-footers && npm run validate:design-skills && npm run validate:question-discipline && npm run validate:spec-artifacts && npm run validate:plan-artifacts && npm run validate:no-deep-refs && npm run validate:agent-section-order && npm run validate:trigger-metadata && npm run validate:trigger-replay && npm run validate:confidence-gates && npm run audit:plugin-package && npm run audit:release-security && npm run lint:dead-code && npm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.6",
    "knip": "^5.30.0",
    "yaml": "^2.6.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "chokidar": "^5.0.0",
    "pptxgenjs": "^4.0.1",
    "web-tree-sitter": "^0.26.8"
  }
}
