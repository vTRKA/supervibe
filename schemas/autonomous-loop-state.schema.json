{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Autonomous Loop State",
  "type": "object",
  "required": [
    "schema_version",
    "command_version",
    "rubric_version",
    "run_id",
    "status",
    "tasks",
    "scores"
  ],
  "properties": {
    "schema_version": { "type": "integer" },
    "command_version": { "type": "integer" },
    "rubric_version": { "type": "integer" },
    "plugin_version": { "type": "string" },
    "run_id": { "type": "string" },
    "status": { "type": "string" },
    "active_task": {},
    "active_agent": {},
    "loop_count": { "type": "integer" },
    "scores": { "type": "array" },
    "budget_remaining": { "type": "object" },
    "last_progress_at": { "type": "string" },
    "stop_reason": {},
    "next_action": { "type": "string" },
    "tasks": { "type": "array" }
  }
}
