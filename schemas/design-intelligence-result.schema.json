{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://supervibe.local/schemas/design-intelligence-result.schema.json",
  "title": "Design Intelligence Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "domain", "kind", "score", "title", "sourcePath", "fields"],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "domain": { "type": "string", "minLength": 2 },
    "kind": { "type": "string", "enum": ["core", "stack", "slides", "collateral"] },
    "stack": { "type": ["string", "null"] },
    "rowNo": { "type": "string" },
    "score": { "type": "number", "minimum": 0 },
    "title": { "type": "string", "minLength": 1 },
    "recommendation": { "type": "string" },
    "sourcePath": { "type": "string", "minLength": 3 },
    "importedPath": { "type": "string" },
    "sourceCommit": { "type": "string" },
    "matchedTokens": { "type": "array", "items": { "type": "string" } },
    "platformScope": { "type": "string" },
    "severity": { "type": ["string", "null"] },
    "fields": { "type": "object" },
    "criticalFields": { "type": "object" }
  }
}
