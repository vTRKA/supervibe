{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://supervibe.local/schemas/autonomous-loop-contract.schema.json",
  "title": "Autonomous Loop Execution Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractId",
    "taskId",
    "purpose",
    "scopeIn",
    "scopeOut",
    "inputs",
    "outputs",
    "sideEffects",
    "forbiddenBehavior",
    "dependencies",
    "targetFiles",
    "moduleType",
    "publicInterfaces",
    "observability",
    "verificationRefs",
    "source"
  ],
  "properties": {
    "contractId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "scopeIn": { "type": "array", "items": { "type": "string" } },
    "scopeOut": { "type": "array", "items": { "type": "string" } },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "sideEffects": { "type": "array", "items": { "type": "string" } },
    "forbiddenBehavior": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "targetFiles": { "type": "array", "items": { "type": "string" } },
    "moduleType": {
      "enum": [
        "ENTRY_POINT",
        "CORE_LOGIC",
        "DATA_LAYER",
        "UI_COMPONENT",
        "UTILITY",
        "INTEGRATION",
        "DOCUMENTATION",
        "INFRASTRUCTURE"
      ]
    },
    "publicInterfaces": { "type": "array", "items": { "type": "string" } },
    "semanticAnchors": { "type": "array", "items": { "type": "object" } },
    "fileLocalContracts": { "type": "array", "items": { "type": "object" } },
    "fileLocalContractRefs": { "type": "array", "items": { "type": "string" } },
    "observability": { "type": "array", "items": { "type": "string" } },
    "verificationRefs": { "type": "array", "items": { "type": "string" } },
    "source": {}
  }
}
