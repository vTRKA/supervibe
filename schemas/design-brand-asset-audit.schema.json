{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://supervibe.local/schemas/design-brand-asset-audit.schema.json",
  "title": "Design Brand Asset Audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["pass", "issues", "palette"],
  "properties": {
    "pass": { "type": "boolean" },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["code", "message", "severity"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["blocker", "warning"] }
        }
      }
    },
    "palette": {
      "type": "object",
      "additionalProperties": true,
      "required": ["approvedCount", "candidateCount", "matchedCandidateColors", "unmatchedCandidateColors", "driftRatio"],
      "properties": {
        "approvedCount": { "type": "integer", "minimum": 0 },
        "candidateCount": { "type": "integer", "minimum": 0 },
        "matchedCandidateColors": { "type": "array", "items": { "type": "string" } },
        "unmatchedCandidateColors": { "type": "array", "items": { "type": "string" } },
        "driftRatio": { "type": "number", "minimum": 0 }
      }
    }
  }
}
