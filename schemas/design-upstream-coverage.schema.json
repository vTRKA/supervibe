{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://supervibe.local/schemas/design-upstream-coverage.schema.json",
  "title": "Design Upstream Coverage",
  "type": "object",
  "additionalProperties": false,
  "required": ["sourceCommit", "families"],
  "properties": {
    "sourceCommit": { "type": "string", "minLength": 7 },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family", "status", "rationale"],
        "properties": {
          "family": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["adapted", "skipped", "deferred-with-rationale"] },
          "rationale": { "type": "string", "minLength": 8 },
          "localPath": { "type": "string" },
          "owner": { "type": "string" }
        }
      }
    }
  }
}
